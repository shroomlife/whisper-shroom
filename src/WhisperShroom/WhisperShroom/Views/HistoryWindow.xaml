<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="WhisperShroom.Views.HistoryWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="WhisperShroom - History">

    <Grid x:Name="RootGrid" Padding="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <TextBlock Text="Transcription History"
                   Style="{StaticResource TitleTextBlockStyle}"
                   Margin="0,0,0,16" />

        <!-- Empty state -->
        <StackPanel Grid.Row="1"
                    x:Name="EmptyState"
                    VerticalAlignment="Center"
                    HorizontalAlignment="Center"
                    Spacing="8">
            <TextBlock Text="No transcriptions yet"
                       Style="{StaticResource SubtitleTextBlockStyle}"
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                       HorizontalAlignment="Center" />
            <TextBlock Text="Transcriptions will appear here after recording."
                       Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                       HorizontalAlignment="Center" />
        </StackPanel>

        <!-- History list -->
        <ScrollViewer Grid.Row="1" x:Name="HistoryScroller">
            <StackPanel x:Name="HistoryPanel" Spacing="8">
                <!-- Day entries + "Clear All" button are added in code-behind -->
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Window>
