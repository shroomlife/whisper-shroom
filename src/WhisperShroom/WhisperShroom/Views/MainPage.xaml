<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="WhisperShroom.Views.MainPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:models="using:WhisperShroom.Models"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <Grid Padding="40">

        <!-- ==================== READY STATE ==================== -->
        <Grid x:Name="ReadyPanel"
              Visibility="{x:Bind IsState(ViewModel.CurrentState, models:AppState.Ready), Mode=OneWay}"
              VerticalAlignment="Center" HorizontalAlignment="Center">
            <StackPanel Spacing="8" HorizontalAlignment="Center">
                <TextBlock Text="&#x1F3A4;" FontSize="48" HorizontalAlignment="Center" />
                <TextBlock Text="Ready to Record"
                           Style="{StaticResource TitleTextBlockStyle}"
                           HorizontalAlignment="Center" />
                <TextBlock Text="{x:Bind ViewModel.HotkeyDisplay, Mode=OneWay}"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,20" />
                <Button Content="Start Recording"
                        Style="{StaticResource AccentButtonStyle}"
                        Command="{x:Bind ViewModel.StartRecordingCommand}"
                        HorizontalAlignment="Center"
                        Padding="24,10" />
            </StackPanel>
        </Grid>

        <!-- ==================== RECORDING STATE ==================== -->
        <Grid x:Name="RecordingPanel"
              Visibility="{x:Bind IsState(ViewModel.CurrentState, models:AppState.Recording), Mode=OneWay}"
              VerticalAlignment="Center" HorizontalAlignment="Center">
            <StackPanel Spacing="8" HorizontalAlignment="Center">
                <Ellipse x:Name="RecordingDot"
                         Width="24" Height="24" Fill="Red"
                         HorizontalAlignment="Center" Margin="0,0,0,8">
                    <Ellipse.Resources>
                        <Storyboard x:Name="PulseAnimation" RepeatBehavior="Forever" AutoReverse="True">
                            <DoubleAnimation Storyboard.TargetName="RecordingDot"
                                             Storyboard.TargetProperty="Opacity"
                                             From="1.0" To="0.2" Duration="0:0:0.5" />
                        </Storyboard>
                    </Ellipse.Resources>
                </Ellipse>

                <TextBlock Text="Recording..."
                           Style="{StaticResource TitleTextBlockStyle}"
                           HorizontalAlignment="Center" />

                <TextBlock Text="{x:Bind ViewModel.RecordingTime, Mode=OneWay}"
                           FontSize="36" FontWeight="Bold"
                           HorizontalAlignment="Center"
                           Margin="0,8,0,8" />

                <InfoBar x:Name="SilenceWarning"
                         IsOpen="{x:Bind ViewModel.ShowSilenceWarning, Mode=OneWay}"
                         Severity="Warning"
                         Title="No Audio Signal Detected"
                         Message="Please check your microphone."
                         IsClosable="False"
                         Margin="0,0,0,12" />

                <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Center">
                    <Button Content="Stop"
                            Style="{StaticResource AccentButtonStyle}"
                            Command="{x:Bind ViewModel.StopRecordingCommand}"
                            Padding="24,10" />
                    <Button Content="Cancel"
                            Command="{x:Bind ViewModel.CancelRecordingCommand}"
                            Padding="24,10" />
                </StackPanel>
            </StackPanel>
        </Grid>

        <!-- ==================== LOADING STATE ==================== -->
        <Grid x:Name="LoadingPanel"
              Visibility="{x:Bind IsState(ViewModel.CurrentState, models:AppState.Loading), Mode=OneWay}"
              VerticalAlignment="Center" HorizontalAlignment="Center">
            <StackPanel Spacing="16" HorizontalAlignment="Center">
                <ProgressRing IsActive="True" Width="48" Height="48" />
                <TextBlock Text="Transcribing..."
                           Style="{StaticResource SubtitleTextBlockStyle}"
                           HorizontalAlignment="Center" />
            </StackPanel>
        </Grid>

        <!-- ==================== RESULT STATE ==================== -->
        <Grid x:Name="ResultPanel"
              Visibility="{x:Bind IsState(ViewModel.CurrentState, models:AppState.Result), Mode=OneWay}"
              RowDefinitions="Auto,*,Auto">

            <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,0,0,16">
                <TextBlock Text="&#x2705;" FontSize="20" VerticalAlignment="Center" />
                <TextBlock Text="Transcription Complete"
                           Style="{StaticResource SubtitleTextBlockStyle}"
                           VerticalAlignment="Center" />
            </StackPanel>

            <ScrollViewer Grid.Row="1" Margin="0,0,0,16">
                <TextBox Text="{x:Bind ViewModel.ResultText, Mode=TwoWay}"
                         TextWrapping="Wrap"
                         AcceptsReturn="True"
                         MinHeight="150"
                         Padding="12" />
            </ScrollViewer>

            <Grid Grid.Row="2" ColumnDefinitions="*,*" ColumnSpacing="12">
                <Button Content="New Recording"
                        Command="{x:Bind ViewModel.NewRecordingCommand}"
                        HorizontalAlignment="Stretch"
                        Padding="0,10" />
                <Button Grid.Column="1"
                        Content="Copy Text"
                        Style="{StaticResource AccentButtonStyle}"
                        Command="{x:Bind ViewModel.CopyTextCommand}"
                        HorizontalAlignment="Stretch"
                        Padding="0,10" />
            </Grid>
        </Grid>

        <!-- ==================== ERROR STATE ==================== -->
        <Grid x:Name="ErrorPanel"
              Visibility="{x:Bind IsState(ViewModel.CurrentState, models:AppState.Error), Mode=OneWay}"
              VerticalAlignment="Center" HorizontalAlignment="Center">
            <StackPanel Spacing="8" HorizontalAlignment="Center">
                <TextBlock Text="&#x26A0;&#xFE0F;" FontSize="36" HorizontalAlignment="Center" />
                <TextBlock Text="Error"
                           Style="{StaticResource SubtitleTextBlockStyle}"
                           Foreground="Red"
                           HorizontalAlignment="Center" />
                <TextBlock Text="{x:Bind ViewModel.ErrorMessage, Mode=OneWay}"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                           TextWrapping="Wrap"
                           MaxWidth="400"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,20" />
                <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Center">
                    <Button Content="Open Settings"
                            Command="{x:Bind ViewModel.OpenSettingsCommand}"
                            Visibility="{x:Bind ViewModel.ShowSettingsOnError, Mode=OneWay}"
                            Padding="24,10" />
                    <Button Content="Retry"
                            Style="{StaticResource AccentButtonStyle}"
                            Command="{x:Bind ViewModel.NewRecordingCommand}"
                            Padding="24,10" />
                </StackPanel>
            </StackPanel>
        </Grid>

    </Grid>
</Page>
