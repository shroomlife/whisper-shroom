<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="WhisperShroom.Views.TextEditorWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="Edit Text">

    <Grid x:Name="RootGrid" Padding="24" Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBox x:Name="EditorBox"
                 AcceptsReturn="True"
                 TextWrapping="Wrap"
                 PlaceholderText="Enter text..."
                 Padding="12"
                 VerticalAlignment="Stretch"
                 HorizontalAlignment="Stretch" />

        <Grid Grid.Row="1" ColumnDefinitions="*,Auto,Auto" ColumnSpacing="8" Margin="0,16,0,0">
            <Button Content="Clear"
                    Click="OnClear"
                    Padding="16,8" />
            <Button Grid.Column="1"
                    Content="Save"
                    Style="{StaticResource AccentButtonStyle}"
                    Click="OnSave"
                    Padding="24,8" />
            <Button Grid.Column="2"
                    Content="Cancel"
                    Click="OnCancel"
                    Padding="24,8" />
        </Grid>
    </Grid>
</Window>
