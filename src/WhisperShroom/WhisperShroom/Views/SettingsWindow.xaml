<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="WhisperShroom.Views.SettingsWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="WhisperShroom - Einstellungen">

    <Grid Padding="32" Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock Text="WhisperShroom - Einstellungen"
                   Style="{StaticResource TitleTextBlockStyle}"
                   Margin="0,0,0,8" />

        <StackPanel Grid.Row="1" Spacing="16">
            <TextBlock Text="Voice-to-Text mit OpenAI Whisper"
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}" />

            <PasswordBox x:Name="ApiKeyBox"
                         Header="OpenAI API Key"
                         PlaceholderText="sk-..."
                         Password="{x:Bind ViewModel.ApiKey, Mode=TwoWay}" />

            <ComboBox x:Name="DeviceCombo"
                      Header="Mikrofon"
                      ItemsSource="{x:Bind ViewModel.DeviceNames, Mode=OneWay}"
                      SelectedItem="{x:Bind ViewModel.SelectedDeviceName, Mode=TwoWay}"
                      HorizontalAlignment="Stretch" />

            <TextBox x:Name="HotkeyBox"
                     Header="Tastenkombination"
                     PlaceholderText="z.B. ctrl+shift+r, alt+r, ctrl+space"
                     Text="{x:Bind ViewModel.Hotkey, Mode=TwoWay}" />

            <InfoBar x:Name="ErrorInfo"
                     IsOpen="False"
                     Severity="Error"
                     Title="Fehler"
                     IsClosable="False" />
        </StackPanel>

        <Grid Grid.Row="2" ColumnDefinitions="*,*" ColumnSpacing="12" Margin="0,24,0,0">
            <Button Content="Speichern"
                    Style="{StaticResource AccentButtonStyle}"
                    HorizontalAlignment="Stretch"
                    Padding="0,10"
                    Click="OnSave" />
            <Button Grid.Column="1"
                    Content="Abbrechen"
                    HorizontalAlignment="Stretch"
                    Padding="0,10"
                    Click="OnCancel" />
        </Grid>
    </Grid>
</Window>
