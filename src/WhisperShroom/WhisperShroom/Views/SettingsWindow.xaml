<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="WhisperShroom.Views.SettingsWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="WhisperShroom - Settings">

    <Grid x:Name="RootGrid" Padding="32" Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock Text="WhisperShroom - Settings"
                   Style="{StaticResource TitleTextBlockStyle}"
                   Margin="0,0,0,8" />

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel Spacing="16">
                <TextBlock Text="Voice-to-Text powered by OpenAI"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}" />

                <PasswordBox x:Name="ApiKeyBox"
                             Header="OpenAI API Key"
                             PlaceholderText="sk-..."
                             Password="{x:Bind ViewModel.ApiKey, Mode=TwoWay}" />

                <ComboBox x:Name="DeviceCombo"
                          Header="Microphone"
                          ItemsSource="{x:Bind ViewModel.DeviceNames, Mode=OneWay}"
                          SelectedItem="{x:Bind ViewModel.SelectedDeviceName, Mode=TwoWay}"
                          HorizontalAlignment="Stretch" />

                <ComboBox Header="Transcription Language"
                          ItemsSource="{x:Bind ViewModel.AvailableLanguages, Mode=OneWay}"
                          SelectedItem="{x:Bind ViewModel.SelectedLanguage, Mode=TwoWay}"
                          HorizontalAlignment="Stretch" />

                <Grid>
                    <ComboBox Header="Transcription Model"
                              ItemsSource="{x:Bind ViewModel.AvailableModels, Mode=OneWay}"
                              SelectedItem="{x:Bind ViewModel.SelectedModel, Mode=TwoWay}"
                              HorizontalAlignment="Stretch" />
                    <ProgressRing IsActive="{x:Bind ViewModel.IsLoadingModels, Mode=OneWay}"
                                  Width="20" Height="20"
                                  HorizontalAlignment="Right" VerticalAlignment="Bottom"
                                  Margin="0,0,48,8" />
                </Grid>

                <TextBox x:Name="HotkeyBox"
                         Header="Hotkey"
                         PlaceholderText="Click and press a key combination"
                         Text="{x:Bind ViewModel.Hotkey, Mode=TwoWay}"
                         IsReadOnly="True"
                         GotFocus="HotkeyBox_GotFocus"
                         LostFocus="HotkeyBox_LostFocus"
                         PreviewKeyDown="HotkeyBox_PreviewKeyDown" />

                <CheckBox Content="Auto-copy to clipboard after transcription"
                          IsChecked="{x:Bind ViewModel.AutoCopyEnabled, Mode=TwoWay}" />

                <CheckBox Content="Show notification when transcription is complete"
                          IsChecked="{x:Bind ViewModel.NotificationsEnabled, Mode=TwoWay}" />

                <StackPanel Spacing="8">
                    <TextBlock Text="Transcription Text Wrapping"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                               FontSize="12" />
                    <Grid ColumnDefinitions="Auto,*" RowDefinitions="Auto,Auto" ColumnSpacing="12" RowSpacing="8">
                        <Button Content="Edit Prefix"
                                Click="OnEditPrefix"
                                MinWidth="100" />
                        <TextBlock Grid.Column="1"
                                   Text="{x:Bind ViewModel.PrefixPreview, Mode=OneWay}"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                   VerticalAlignment="Center"
                                   TextTrimming="CharacterEllipsis" />

                        <Button Grid.Row="1"
                                Content="Edit Suffix"
                                Click="OnEditSuffix"
                                MinWidth="100" />
                        <TextBlock Grid.Row="1" Grid.Column="1"
                                   Text="{x:Bind ViewModel.SuffixPreview, Mode=OneWay}"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                   VerticalAlignment="Center"
                                   TextTrimming="CharacterEllipsis" />
                    </Grid>
                </StackPanel>

                <InfoBar x:Name="ErrorInfo"
                         IsOpen="False"
                         Severity="Error"
                         Title="Error"
                         IsClosable="False" />
            </StackPanel>
        </ScrollViewer>

        <Grid Grid.Row="2" ColumnDefinitions="*,*" ColumnSpacing="12" Margin="0,24,0,0">
            <Button Content="Save"
                    Style="{StaticResource AccentButtonStyle}"
                    HorizontalAlignment="Stretch"
                    Padding="0,10"
                    Click="OnSave" />
            <Button Grid.Column="1"
                    Content="Cancel"
                    HorizontalAlignment="Stretch"
                    Padding="0,10"
                    Click="OnCancel" />
        </Grid>
    </Grid>
</Window>
